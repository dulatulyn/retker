# --- безопасность (продакшн) ---
# длинный случайный секрет для подписи JWT (минимум 32 байта)
RETKER_SECRET=change-me-to-a-long-random-secret-min-32-bytes

# --- LLM-провайдеры ---
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

AI_PROVIDER_ORDER=gemini,openai,anthropic
GEMINI_MODEL=gemini-2.0-flash
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

AI_OFFLINE=0
AI_HTTP_TIMEOUT=30
AI_MAX_TOKENS=1024
AI_TEMPERATURE=0.3
AI_AGENT_MAX_STEPS=5
